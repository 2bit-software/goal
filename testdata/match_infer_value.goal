package app

enum Color {
    Red
    Green
}

enum Label {
    Hot
    Cold
}

func classify(c Color) Label {
    label := match c {
        Color.Red => Label.Hot
        Color.Green => Label.Cold
    }
    return label
}

func name(c Color) string {
    s := match c {
        Color.Red => "red"
        Color.Green => "green"
    }
    return s
}

// warm infers `bool` for a value-position `x := match` whose arms are
// boolean-valued expressions (comparison / logical `&&` / `!`), which
// previously needed an explicit `var x bool = match ...` annotation.
func warm(c Color, a int, b int) bool {
    x := match c {
        Color.Red => a == b
        Color.Green => a < b && !(b > a)
    }
    return x
}
