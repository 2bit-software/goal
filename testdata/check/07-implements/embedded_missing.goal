package io2

// Sink implements ReadWriter but only defines Write — the method inherited through the
// embedded Reader interface (Read) is missing. The check folds the embedded obligation
// in, so it must catch the absent embedded method too.
type Reader interface {
	Read(p []byte) (int, error)
}

type ReadWriter interface {
	Reader
	Write(p []byte) (int, error)
}

type Sink struct implements ReadWriter { // want "missing method `Read("
	n int
}

func (s Sink) Write(p []byte) (int, error) {
	return len(p), nil
}
