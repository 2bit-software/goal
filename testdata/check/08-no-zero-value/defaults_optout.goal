package users

type Role int

const (
	RoleMember Role = iota
)

type User struct {
	name   string
	email  string
	role   Role
	active bool
	logins int
}

// newMember sets the no-default fields and opts the rest into their zeros with
// `...defaults` — the literal is complete by construction, so no missing-field error.
func newMember(name string) User {
	return User{name: name, role: RoleMember, ...defaults}
}
