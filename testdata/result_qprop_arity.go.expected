package app

func mkdir(path string) error {
	return nil
}

func lookup(id string) (__goal_ok string, __goal_err error) {
	return id, nil
}

func handler(id string) (__goal_ok string, __goal_err error) {
	if __goal_err := mkdir(id); __goal_err != nil {
		return __goal_ok, __goal_err
	}
	u, __goal_err := lookup(id)
	if __goal_err != nil {
		return __goal_ok, __goal_err
	}
	return u, nil
}
