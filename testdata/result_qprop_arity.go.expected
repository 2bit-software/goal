package app

func mkdir(path string) error {
	return nil
}

func lookup(id string) (ok string, err error) {
	return id, nil
}

func handler(id string) (ok string, err error) {
	if err := mkdir(id); err != nil {
		return ok, err
	}
	u, err := lookup(id)
	if err != nil {
		return ok, err
	}
	return u, nil
}
