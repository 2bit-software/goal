package app

import "errors"

type User struct {
	ID   string
	Name string
}

type Page struct {
	Title string
}

func lookup(id string) (ok User, err error) {
	if id == "" {
		return ok, errors.New("empty id")
	}
	return User{ID: id, Name: "n"}, nil
}

func render(u User) (ok Page, err error) {
	return Page{Title: u.Name}, nil
}

func handler(id string) (ok Page, err error) {
	u, err := lookup(id)
	if err != nil {
		return ok, err
	}
	p, err := render(u)
	if err != nil {
		return ok, err
	}
	return p, nil
}
