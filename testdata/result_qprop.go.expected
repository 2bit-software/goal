package app

import "errors"

type User struct {
	ID   string
	Name string
}

type Page struct {
	Title string
}

func lookup(id string) (__gop_ok User, __gop_err error) {
	if id == "" {
		return __gop_ok, errors.New("empty id")
	}
	return User{ID: id, Name: "n"}, nil
}

func render(u User) (__gop_ok Page, __gop_err error) {
	return Page{Title: u.Name}, nil
}

func handler(id string) (__gop_ok Page, __gop_err error) {
	u, __gop_err := lookup(id)
	if __gop_err != nil {
		return __gop_ok, __gop_err
	}
	p, __gop_err := render(u)
	if __gop_err != nil {
		return __gop_ok, __gop_err
	}
	return p, nil
}
