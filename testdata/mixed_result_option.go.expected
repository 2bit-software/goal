package app

import "errors"

type User struct {
	ID   string
	Name string
}

func lookup(id string) (ok User, err error) {
	if id == "" {
		return ok, errors.New("empty id")
	}
	return User{ID: id, Name: "n"}, nil
}

func cache(id string) *User {
	if id == "x" {
		some := User{ID: id, Name: "cached"}
		return &some
	}
	return nil
}

func describe(id string) (ok string, err error) {
	u, err := lookup(id)
	if err != nil {
		return ok, err
	}
	return u.Name, nil
}

func firstName(id string) *string {
	o := cache(id)
	if o == nil {
		return nil
	}
	u := *o
	some := u.Name
	return &some
}

func handle(id string) {
	v, err := lookup(id)
	if err != nil {
		fail(err)
	} else {
		report(v.Name)
	}
	if o := cache(id); o != nil {
		u := *o
		report(u.Name)
	} else {
		done()
	}
}

func report(s string) {
}

func fail(e error) {
}

func done() {
}
