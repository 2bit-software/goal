package app

import "errors"

type Time = int64

type Event interface{ isEvent() }

type Event_Login struct {
	User string
}
type Event_Logout struct {
	User string
	At   Time
}
type Event_Failure struct {
	Reason string
}

func (Event_Login) isEvent()   {}
func (Event_Logout) isEvent()  {}
func (Event_Failure) isEvent() {}

func classify(code int) (__goal_ok Event, __goal_err error) {
	if code < 0 {
		return __goal_ok, errors.New("bad code")
	}
	return Event(Event_Login{User: "alice"}), nil
}

func describe(code int) (__goal_ok string, __goal_err error) {
	ev, __goal_err := classify(code)
	if __goal_err != nil {
		return __goal_ok, __goal_err
	}
	var label string
	switch __goal_v := ev.(type) {
	case Event_Login:
		label = __goal_v.User
	case Event_Logout:
		label = __goal_v.User
	case Event_Failure:
		label = __goal_v.Reason
	default:
		panic("unreachable: non-exhaustive Event (compiler invariant violated)")
	}
	return label, nil
}
