package app

import "errors"

type Time = int64

type Event interface{ isEvent() }

type Event_Login struct {
	User string
}
type Event_Logout struct {
	User string
	At   Time
}
type Event_Failure struct {
	Reason string
}

func (Event_Login) isEvent()   {}
func (Event_Logout) isEvent()  {}
func (Event_Failure) isEvent() {}

func classify(code int) (ok Event, err error) {
	if code < 0 {
		return ok, errors.New("bad code")
	}
	return Event(Event_Login{User: "alice"}), nil
}

func describe(code int) (ok string, err error) {
	ev, err := classify(code)
	if err != nil {
		return ok, err
	}
	var label string
	switch v := ev.(type) {
	case Event_Login:
		label = v.User
	case Event_Logout:
		label = v.User
	case Event_Failure:
		label = v.Reason
	default:
		panic("unreachable: non-exhaustive Event (compiler invariant violated)")
	}
	return label, nil
}
