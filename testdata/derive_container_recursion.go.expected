package app

type ID struct {
	v string
}

func parseID(s string) ID {
	return ID{v: s}
}

type Raw struct {
	Tags  []string
	Index map[string]string
	Pair  [2]string
	Lead  *string
	Maybe *string
}

type Typed struct {
	Tags  []ID
	Index map[string]ID
	Pair  [2]ID
	Lead  *ID
	Maybe *ID
}

func toTyped(r Raw) Typed {
	var out Typed
	out.Tags = make([]ID, len(r.Tags))
	for i := range r.Tags {
		out.Tags[i] = parseID(r.Tags[i])
	}
	out.Index = make(map[string]ID, len(r.Index))
	for k, v1 := range r.Index {
		out.Index[k] = parseID(v1)
	}
	for i1 := range r.Pair {
		out.Pair[i1] = parseID(r.Pair[i1])
	}
	if r.Lead != nil {
		p := parseID(*r.Lead)
		out.Lead = &p
	}
	if r.Maybe != nil {
		p1 := parseID(*r.Maybe)
		out.Maybe = &p1
	}
	return out
}
