# Go build output
*.exe
*.test
*.out
/bin/
# Self-host bootstrap + fixpoint artifacts (rebuild with `task bootstrap`/`task fixpoint`)
/_bootstrap/
# Compiled reference transpilers (rebuild with `go build` in each dir)
features/*/transpiler/transpiler
features/_cut/*/transpiler/transpiler

# Editor / OS
.DS_Store

# morse-code runtime state (per-developer loop state, not shared)
.morse-code/state.json
.morse-code/initiative.json
morse-code.local.yaml

# Generated playground artifacts (rebuild with scripts/build-site.sh)
/site/goal.wasm
/site/wasm_exec.js
/site/features.json
