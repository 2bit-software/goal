package config

type Addr struct {
	host string
	port int
}

type Name = string

type Settings struct {
	primary  Addr
	fallback *Addr
	meta     Addr
	tags     []string
	env      map[string]string
	label    Name
	retries  int
}

func defaultSettings() Settings {
	return Settings{primary: Addr{host: "localhost", port: 8080}, fallback: nil, env: map[string]string{}, meta: Addr{}, tags: nil, label: "", retries: 0}
}
