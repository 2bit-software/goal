package parse

enum ParseError {
    Empty
    BadKey { key: string }
}

type Config struct {
    Raw string
}

func parse(s string) Result[Config, ParseError] {
    if s == "" {
        return Result.Err(ParseError.Empty)
    }
    return Result.Ok(Config{Raw: s})
}

func loadFirst(a string) Result[Config, ParseError] {
    cfg := parse(a)?
    return Result.Ok(cfg)
}
