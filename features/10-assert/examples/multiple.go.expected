package ranges

import "fmt"

func check(lo int, hi int, n int) {
	if !(lo <= hi) {
		panic("assertion failed: lo <= hi")
	}
	if !(clamp(lo, hi, n) == n) {
		panic("assertion failed: clamp(lo, hi, n) == n: " + fmt.Sprintf("n=%d not in [%d, %d]", n, lo, hi))
	}
	if !(n%2 == 0) {
		panic("assertion failed: n % 2 == 0")
	}
}

func clamp(lo int, hi int, n int) int {
	if n < lo {
		return lo
	}
	if n > hi {
		return hi
	}
	return n
}
