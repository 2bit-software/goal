package users

type User struct {
	Name string
}

func find(name string) *User {
	return nil
}

func parent(name string) *User {
	return nil
}

func grandparent(name string) *User {
	o := find(name)
	if o == nil {
		return nil
	}
	u := *o
	o1 := parent(u.Name)
	if o1 == nil {
		return nil
	}
	p := *o1
	some := p
	return &some
}
