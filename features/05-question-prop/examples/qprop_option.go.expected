}

func grandparent(name string) *User {
	__goal_o1 := find(name)
	if __goal_o1 == nil {
		return nil
	}
	u := *__goal_o1
	__goal_o2 := parent(u.Name)
	if __goal_o2 == nil {
		return nil
	}
	p := *__goal_o2
	return &p
}
