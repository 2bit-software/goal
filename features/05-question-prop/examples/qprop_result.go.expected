package config

type Config struct {
	Raw string
}

func readFile(p string) (ok []byte, err error) {
	return []byte(p), nil
}

func parse(raw []byte) (ok Config, err error) {
	return Config{Raw: string(raw)}, nil
}

func loadConfig(p string) (ok Config, err error) {
	raw, err := readFile(p)
	if err != nil {
		return ok, err
	}
	cfg, err := parse(raw)
	if err != nil {
		return ok, err
	}
	return cfg, nil
}
