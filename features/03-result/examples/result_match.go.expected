package config

import "errors"

type Config struct {
	Raw string
}

func parse(s string) (ok Config, err error) {
	if s == "" {
		return ok, errors.New("empty input")
	}
	return Config{Raw: s}, nil
}

func run(c Config) {
}

func report(e error) {
}

func done() {
}

func handle(input string) {
	v, err := parse(input)
	if err != nil {
		report(err)
	} else {
		run(v)
	}
}

func handle2(input string) {
	_, err := parse(input)
	if err != nil {
		report(err)
	} else {
		done()
	}
}
