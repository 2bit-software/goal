package users

type ID int

type User struct {
	Name string
}

func lookup(id ID) (User, bool) {
	return User{}, false
}

func find(id ID) *User {
	u, ok := lookup(id)
	if !ok {
		return nil
	}
	some := u
	return &some
}

func greet(u User) {
