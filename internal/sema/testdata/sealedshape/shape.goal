package shape

// Node is a SEALED interface DEFINED in this sibling .goal package (no generated .go
// beside it) — the real per-package `goal build ./selfhost` topology SEAM-CAP-3c targets.
// A consumer package matching over Node must read these implementors straight from .goal
// source to resolve and exhaustiveness-check the cross-package type-pattern match.
sealed interface Node {}

type Lit struct implements Node {
	Val int
}

type Neg struct implements Node {
	Inner Node
}
