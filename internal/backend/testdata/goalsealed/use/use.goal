package use

import shape "goal/internal/backend/testdata/goalsealed/shape"

// eval matches over a SEALED INTERFACE defined in a SIBLING .goal package — the
// cross-.goal-package type-pattern match SEAM-CAP-3c must resolve and lower (previously the
// implementor set was invisible to this consumer, so the match deferred with
// `unresolved-match-sealed`). It lowers to a Go type-switch with `case *shape.Lit:` /
// `case *shape.Neg:`, identical to a hand-written `switch x := n.(type)`.
func eval(n shape.Node) int {
	return match n {
		*shape.Lit(l) => l.Val
		*shape.Neg(g) => -eval(g.Inner)
	}
}
