package shape

// Node is a SEALED interface DEFINED in this sibling .goal package, with NO generated .go
// beside it — the real per-package `goal build` topology SEAM-CAP-3c targets. A dependent
// package matching over Node must read these implementors straight from .goal source to
// resolve and lower the cross-package type-pattern match.
sealed interface Node {}

type Lit struct implements Node {
	Val int
}

type Neg struct implements Node {
	Inner Node
}
