package valopt

type ID int

type User struct {
	Name string
}

func find(id ID) Option[User] {
	return Option.None
}

// describeO returns the outcome of an Option match directly (return position),
// using the Some payload binding.
func describeO(id ID) string {
	return match find(id) {
		Option.Some(u) => u.Name
		Option.None => "none"
	}
}

// tagO binds the outcome of an Option match to a variable (assignment position).
func tagO(id ID) string {
	tag := match find(id) {
		Option.Some(u) => "found"
		Option.None => "missing"
	}
	return tag
}
