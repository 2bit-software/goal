package main

import "fmt"

// Shape is a sum type carrying behaviour through value-receiver methods (US-001).
enum Shape {
    Circle { r: float64 }
    Rect { w: float64, h: float64 }
}

// Area dispatches on the variant through a value-position match.
func (s Shape) Area() float64 {
    return match s {
        Shape.Circle(c) => 3 * c.r * c.r
        Shape.Rect(r) => r.w * r.h
    }
}

// Scaled takes a parameter and calls another method on the same sum type, so the
// method set must be folded into the enum interface for `s.Area()` to resolve.
func (s Shape) Scaled(factor float64) float64 {
    return s.Area() * factor
}

// Dims returns two values (width, isRect).
func (s Shape) Dims() (float64, bool) {
    var isRect bool = match s {
        Shape.Circle(c) => c.r < 0
        Shape.Rect(r) => r.w >= 0
    }
    return s.Area(), isRect
}

func main() {
    var c Shape = Shape.Circle(r: 2)
    var r Shape = Shape.Rect(w: 3, h: 4)
    cw, cRect := c.Dims()
    rw, rRect := r.Dims()
    fmt.Printf("%.1f %.1f %.1f %v\n", c.Area(), c.Scaled(2), cw, cRect)
    fmt.Printf("%.1f %.1f %.1f %v\n", r.Area(), r.Scaled(2), rw, rRect)
}
