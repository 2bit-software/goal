package use

import mood "goal/internal/backend/testdata/goalenum/mood"

// label matches an enum defined in a SIBLING .goal package — the cross-.goal-package
// match SEAM-CAP-2 must lower (previously: unsupported expression *ast.MatchExpr,
// because the sibling-.goal-defined enum was invisible to this consumer).
func label(m mood.Mood) string {
	return match m {
		mood.Mood.Happy => "happy"
		mood.Mood.Sad => "sad"
	}
}

// pick is a bare construction of a cross-.goal-package variant. It must lower to the
// §8.1 form `mood.Mood(mood.Mood_Happy{})`, not emit verbatim invalid Go.
func pick() mood.Mood {
	return mood.Mood.Happy
}
