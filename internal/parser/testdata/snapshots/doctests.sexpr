(File
  .Name (Ident
    .Name "mathx")
  .Decls [
    (FuncDecl
      .Doc (DocComment
        .Lines [
          "Adds two ints."
          ">>> add(2, 3)"
          "5"
        ]
        .Doctests [
          (Doctest
            .Input "add(2, 3)"
            .Expected [
              "5"
            ])
        ])
      .Name (Ident
        .Name "add")
      .Type (FuncType
        .Params (FieldList
          .List [
            (Field
              .Names [
                (Ident
                  .Name "a")
              ]
              .Type (Ident
                .Name "int"))
            (Field
              .Names [
                (Ident
                  .Name "b")
              ]
              .Type (Ident
                .Name "int"))
          ])
        .Results (FieldList
          .List [
            (Field
              .Type (Ident
                .Name "int"))
          ]))
      .Body (BlockStmt
        .List [
          (ReturnStmt
            .Results [
              (BinaryExpr
                .X (Ident
                  .Name "a")
                .Op +
                .Y (Ident
                  .Name "b"))
            ])
        ]))
  ])
