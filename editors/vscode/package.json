{
  "name": "goal-lang",
  "displayName": "Goal",
  "description": "Language support for the Goal language (.goal): syntax highlighting plus inline diagnostics from the goal language server.",
  "version": "0.2.0",
  "publisher": "goal-lang",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "goal",
    "go",
    "golang",
    "syntax"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/2bit-software/goal.git",
    "directory": "editors/vscode"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:goal"
  ],
  "contributes": {
    "languages": [
      {
        "id": "goal",
        "aliases": [
          "Goal",
          "goal"
        ],
        "extensions": [
          ".goal"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "goal",
        "scopeName": "source.goal",
        "path": "./syntaxes/goal.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Goal",
      "properties": {
        "goal.lsp.path": {
          "type": "string",
          "default": "goal",
          "description": "Path to the goal binary used to run the language server (`goal lsp`). Resolved on PATH by default."
        },
        "goal.lsp.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the goal language server (inline diagnostics)."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs --production",
    "package": "npm run build && vsce package",
    "install-local": "npm run build && vsce package -o goal-lang.vsix && code --install-extension goal-lang.vsix --force",
    "test": "node test/tokenize.test.mjs"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.82.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.4.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.0.0"
  }
}
